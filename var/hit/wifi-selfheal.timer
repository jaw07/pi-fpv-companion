[Unit]
Description=Run pi-fpv-companion WiFi self-heal after boot and periodically

[Timer]
# First check ~45s after boot (covers a stalled post-reboot association),
# then every 2 minutes to recover from later drops.
OnBootSec=45s
OnUnitActiveSec=120s
AccuracySec=10s

[Install]
WantedBy=timers.target
